{"data":{"node_info":{"unique_id":"test.airbnb.relationships_fct_reviews_2f397514d7615e5ae30d8fce9f0ea58d.ba838561e0"},"sql":"create or replace transient  table AIRBNB.DEV_test_results.relationships_fct_reviews_2f397514d7615e5ae30d8fce9f0ea58d\n    \n    \n    \n    as (\n    \n  \n    \n    \n\nwith child as (\n    select listing_id as from_field\n    from AIRBNB.DEV.fct_reviews\n    where listing_id is not null\n),\n\nparent as (\n    select listing_id as to_field\n    from AIRBNB.DEV.dim_listings_cleansed\n)\n\nselect\n    from_field\n\nfrom child\nleft join parent\n    on child.from_field = parent.to_field\n\nwhere parent.to_field is null\n\n\n\n  \n  \n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"2.0.0\", \"node_id\": \"test.airbnb.relationships_fct_reviews_2f397514d7615e5ae30d8fce9f0ea58d.ba838561e0\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\"} */"},"info":{"category":"","code":"E017","extra":{},"invocation_id":"019d49d3-a34f-7171-929b-7c2e3016913a","level":"debug","msg":"-- created_at: 2026-04-01T16:15:16.466750800+00:00\n-- finished_at: 2026-04-01T16:15:17.521428+00:00\n-- elapsed: 1.1s\n-- outcome: success\n-- dialect: snowflake\n-- node_id: test.airbnb.relationships_fct_reviews_2f397514d7615e5ae30d8fce9f0ea58d.ba838561e0\n-- query_id: 01c36bcf-3203-dfa2-0007-7a2e0003026e\n-- desc: execute adapter call\ncreate or replace transient  table AIRBNB.DEV_test_results.relationships_fct_reviews_2f397514d7615e5ae30d8fce9f0ea58d\n    \n    \n    \n    as (\n    \n  \n    \n    \n\nwith child as (\n    select listing_id as from_field\n    from AIRBNB.DEV.fct_reviews\n    where listing_id is not null\n),\n\nparent as (\n    select listing_id as to_field\n    from AIRBNB.DEV.dim_listings_cleansed\n)\n\nselect\n    from_field\n\nfrom child\nleft join parent\n    on child.from_field = parent.to_field\n\nwhere parent.to_field is null\n\n\n\n  \n  \n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"2.0.0\", \"node_id\": \"test.airbnb.relationships_fct_reviews_2f397514d7615e5ae30d8fce9f0ea58d.ba838561e0\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\"} */;","name":"SQLQuery","pid":23196,"thread":"tokio-runtime-worker","ts":"2026-04-01T16:15:17.521456Z"}}
