{"data":{"node_info":{"unique_id":"test.airbnb.consistent_created_at.0dc3d99b2e"},"sql":"create or replace transient  table AIRBNB.DEV_test_results.consistent_created_at\n    \n    \n    \n    as (\n    \n  SELECT * FROM AIRBNB.DEV.dim_listings_cleansed l\r\nINNER JOIN AIRBNB.DEV.fct_reviews r\r\nUSING (listing_id)\r\nWHERE l.created_at > r.review_date\n  \n  \n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"2.0.0\", \"node_id\": \"test.airbnb.consistent_created_at.0dc3d99b2e\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\"} */"},"info":{"category":"","code":"E017","extra":{},"invocation_id":"019d49d7-7970-7a72-9405-77744211c74e","level":"debug","msg":"-- created_at: 2026-04-01T16:19:19.575710100+00:00\n-- finished_at: 2026-04-01T16:19:23.644917100+00:00\n-- elapsed: 4.1s\n-- outcome: success\n-- dialect: snowflake\n-- node_id: test.airbnb.consistent_created_at.0dc3d99b2e\n-- query_id: 01c36bd3-3203-dfa2-0007-7a2e000302ae\n-- desc: execute adapter call\ncreate or replace transient  table AIRBNB.DEV_test_results.consistent_created_at\n    \n    \n    \n    as (\n    \n  SELECT * FROM AIRBNB.DEV.dim_listings_cleansed l\r\nINNER JOIN AIRBNB.DEV.fct_reviews r\r\nUSING (listing_id)\r\nWHERE l.created_at > r.review_date\n  \n  \n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"2.0.0\", \"node_id\": \"test.airbnb.consistent_created_at.0dc3d99b2e\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\"} */;","name":"SQLQuery","pid":13364,"thread":"tokio-runtime-worker","ts":"2026-04-01T16:19:23.644932Z"}}
